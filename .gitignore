src/img/_icons.scss
public/css/main.css
public/css/icons.css
# generated types
.astro/
# wrangler local state (cloudflare deploy)
.wrangler/
# deps
node_modules/
# env
.env
.env.production
# local test-content runner (points the loader + gen-scripts at an out-of-repo dir)
dev-content.sh
# logs
npm-debug.log*
# macOS
.DS_Store
# personal Claude Code config + hooks (not shared; fan-out workers don't push)
.claude/
