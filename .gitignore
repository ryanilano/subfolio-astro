# build output
dist/
# pre-generated thumbnail cache (scripts/gen-thumbs.mjs)
.thumb-cache/
# pre-fetched RSS feed cache (scripts/gen-rss.mjs)
.rss-cache/
# pre-built .oplx zip cache (scripts/gen-oplx.mjs)
.oplx-cache/
# pre-generated embed WebP cache (scripts/gen-embeds.mjs)
.embed-cache/
# generated CSS + icon Sass map (scripts/gen-css.mjs) — compiled from src/styles + src/img/svg_source
src/img/_icons.scss
public/css/main.css
public/css/icons.css
public/css/theme-*.css
# generated types
.astro/
# wrangler local state (cloudflare deploy)
.wrangler/
# deps
node_modules/
# env
.env
.env.production
# logs
npm-debug.log*
# local-only scratch + Claude Code session logs (untracked, never pushed)
.local/
# macOS
.DS_Store
# personal Claude Code config + hooks (not shared; fan-out workers don't push).
# Ignore the contents but NOT the dir itself, so the skills exception below can
# re-include them (git won't descend into a fully-excluded directory).
.claude/*
# ...but DO version-control shared skills (the handoff workflow, etc.)
!.claude/skills/
# legacy PHP Subfolio config dump — local reference for diffing, never committed
config-legacy/
