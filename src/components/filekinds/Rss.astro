---
/**
 * RSS filekind view — ported from upstream pages/filekinds/rss.php.
 *
 * Consumes a FileViewData prop + RSS items the route reads from the build-time
 * cache (scripts/gen-rss.mjs → src/lib/rssFeed.ts). The fetch happens in the
 * pre-build pass; items arrive here as props.
 *
 * Wave component — mirrors Img.astro prop-signature pattern.
 */
import type { FileViewData } from "../../lib/fileHelpers.ts";
import type { RssItem } from "../../lib/rssFeed.ts";

interface Props {
  file: FileViewData;
  items: RssItem[];
}

const { items } = Astro.props;
---

<ul class="rss">
  {items.map((item) => (
    <li class="standard_paragraph item">
      <h4>{item.title}</h4>
      <p>{item.description}</p>
      <p><a target="_blank" href={item.link}>Read more</a></p>
    </li>
  ))}
</ul>
