---
/**
 * Files and folders listing — ported from upstream pages/listing/files_and_folders.php.
 *
 * Consumes a FolderEntry and renders the list/grid of child files and folders,
 * preserving PHP markup classes and structure for visual diffing.
 *
 * Wave component — port/listing-files-and-folders (C13).
 */
import { fileURLToPath } from "node:url";
import { defaultOptions, type Options } from "../../lib/site.ts";
import { t } from "../../lib/i18n.ts";
import {
  buildListingItems,
  type ListingItem,
  type ListingContext,
} from "../../lib/listingHelpers.ts";
import type { FolderEntry } from "../../loaders/schema.ts";

interface Props {
  /** The folder entry whose children are listed. */
  entry: FolderEntry;
  /** Display options override (merge with defaults). */
  options?: Partial<Options>;
  /** Context for resolving filesystem stats and paths. */
  context?: Partial<ListingContext>;
}

const { entry, options: opts = {}, context: ctx = {} } = Astro.props;

// Merge props over defaults
const opt: Options = { ...defaultOptions, ...opts };
const listingCtx: ListingContext = {
  contentRoot: ctx.contentRoot ?? fileURLToPath(new URL("../../content/examples/", import.meta.url)),
  folderPath: ctx.folderPath ?? `${entry.path}/`,
};

// Build listing items (mirrors SubfolioFiles::files_and_folders())
const items: ListingItem[] = buildListingItems(entry, listingCtx, opt);

const haveFiles = items.length > 0;
const isEmptyFolder = entry.files.length === 0 && entry.folders.length === 0;
const isGrid = opt.listing_mode === "grid";
---

{
  haveFiles ? (
    <div class="listing">
      <div class={`list list--${opt.listing_mode}`} data-behavior="hover_list">

        {/* Header row (hidden in grid mode) */}
        {opt.display_file_listing_header && !isGrid && (
          <div class="list__row list__header">
            {opt.display_name && (
              <span class="list__cell list__cell--filename"><span>{t("filename")}</span></span>
            )}
            {opt.display_size && (
              <span class="list__cell list__cell--size"><span>{t("size")}</span></span>
            )}
            {opt.display_date && (
              <>
                <span class="list__cell list__cell--updated"></span>
                <span class="list__cell list__cell--date"><span>{t("date")}</span></span>
              </>
            )}
            {opt.display_kind && (
              <span class="list__cell list__cell--kind"><span>{t("kind")}</span></span>
            )}
            {opt.display_comment && (
              <span class="list__cell list__cell--comment">{t("comment")}</span>
            )}
          </div>
        )}

        {/* Item rows */}
        {items.map((item) => {
          const iconType = isGrid ? item.iconGrid : item.icon;
          return (
            <a
              class={`list__row list__body${item.empty ? " list__row--empty" : ""} focusable`}
              target={item.target}
              href={item.url}
            >
              {/* FILENAME */}
              {opt.display_name && (
                <span class="list__cell list__cell--filename">
                  {/* ICON */}
                  {opt.display_icons ? (
                    <span class="list__cell--filenameicon">
                      {item.restricted ? (
                        <i class={`icon icon__${iconType}_${item.haveAccess ? "shared" : "protected"}`} aria-hidden="true"></i>
                      ) : (
                        <i class={`icon icon__${iconType}`} aria-hidden="true"></i>
                      )}
                    </span>
                  ) : (
                    <span class="list__cell list__cell--no_icon"></span>
                  )}
                  <span class="list__cell--filenametext">{item.filename}</span>
                </span>
              )}

              {/* OTHER COLUMNS */}
              {opt.display_size && <span class="list__cell list__cell--size">{item.size}</span>}

              {opt.display_date && (
                <>
                  <span class="list__cell list__cell--updated">
                    {item.isNew ? (
                      <span class="updated updated--new"></span>
                    ) : (
                      <span class={`updated${item.isUpdated ? " updated--new" : ""}`}></span>
                    )}
                  </span>
                  <span class="list__cell list__cell--date">{item.date}</span>
                </>
              )}
              {opt.display_kind && <span class="list__cell list__cell--kind">{item.kind}</span>}
              {opt.display_comment && <span class="list__cell list__cell--comment">{item.comment}</span>}
            </a>
          );
        })}

      </div>
    </div>
  ) : (
    <>
      {isEmptyFolder && <p>{t("emptyfolder")}</p>}
    </>
  )
}
