---
/**
 * Gallery listing view — ported from upstream pages/listing/gallery.php.
 *
 * Consumes a FolderEntry. Filters to image-kind files and renders a
 * thumbnail gallery in the active listing mode (list/grid/masonry).
 *
 * Phase 3: uses thumbnail pipeline for auto-generated / custom thumbnails,
 * shadow/browser suffix detection via imageMeta.
 *
 * Wave component — C12.
 */
import { resolve } from "node:path";
import { defaultOptions } from "../../lib/site.ts";
import { pageUrl } from "../../lib/routing.ts";
import { imageMetaFor } from "../../lib/imageMeta.ts";
import { thumbnailFor } from "../../lib/thumbnailPipeline.ts";
import type { ThumbnailResult } from "../../lib/thumbnailPipeline.ts";
import type { FolderEntry } from "../../loaders/schema.ts";

const contentRoot = resolve(process.env.SUBFOLIO_CONTENT_DIR ?? "./content/examples");

interface GalleryImage {
  width: number;
  height: number;
  shadow: boolean;
  browser: boolean;
  containerWidth: number;
  containerHeight: number;
  class: string;
  link: string;
  filename: string;
  url: string;
}

interface Props {
  entry: FolderEntry;
  /** Listing mode override. Defaults to site options. */
  listingMode?: string;
  /**
   * Accepted for call-site compatibility; URLs are derived from entry.path.
   * @deprecated paths now come from entry.path via assetUrl()/pageUrl().
   */
  folderPath?: string;
}

const { entry, listingMode = defaultOptions.listing_mode } = Astro.props;

// Filter to image files only (mirrors SubfolioFiles::gallery_images)
const imageFiles = entry.files.filter((f) => f.kind === "img");

// Build gallery image entries (mirrors SubfolioFiles::gallery_images loop)
const thumbnailHeight = defaultOptions.thumbnail_height;
const displayFilenames = defaultOptions.display_file_names_in_gallery;

// Canonical "/"-relative folder path (root "." → "") for URL building.
const relDir = entry.path === "." ? "" : entry.path;

const galleryEntries = await Promise.all(
  imageFiles.map(async (file) => {
    const relPath = relDir ? `${relDir}/${file.name}` : file.name;
    const meta = await imageMetaFor(relPath);

    // Run the thumbnail pipeline (SPEC-thumbnails §3.7)
    const thumb: ThumbnailResult = await thumbnailFor(relPath, contentRoot, listingMode);

    // Suppress if pipeline returned empty (generation failed/skipped — SPEC §3.6)
    if (thumb.url === "") {
      return null;
    }

    // Custom thumbnails use natural dimensions; auto-gen use thumbnailHeight for
    // container height (SPEC-thumbnails §3.7)
    const isCustom = thumb.kind === "custom";
    const thumbClass = isCustom ? "gallery_thumbnail custom" : "gallery_thumbnail";

    const image: GalleryImage = {
      width: meta.width,
      height: meta.height,
      shadow: meta.hasShadow,
      browser: meta.hasBrowser,
      containerWidth: isCustom ? meta.width : meta.width,
      containerHeight: isCustom ? meta.height : thumbnailHeight,
      class: thumbClass,
      link: pageUrl(relPath),
      filename: file.displayName,
      url: thumb.url,
    };
    return { image, rawHeight: meta.height };
  }),
);

// Filter out nulls (pipeline returns "" url) and images at-or-below thumbnail
// height (SPEC-thumbnails §3.8). height 0 = undecodable, keep it.
const galleryImages: GalleryImage[] = galleryEntries
  .filter((e) => e !== null)
  .filter((e) => e.rawHeight === 0 || e.rawHeight > thumbnailHeight)
  .map((e) => e.image);

/** Build the inline style for the container wrapper div. */
function containerStyle(img: GalleryImage, isMasonry: boolean): string | undefined {
  if (isMasonry) return undefined;
  return `max-height:${img.containerHeight}px`;
}

/** Build the inline style for the <img> tag. */
function imgStyle(img: GalleryImage, isMasonry: boolean): string | undefined {
  const parts: string[] = [];
  if (!isMasonry) {
    parts.push(`max-height:${img.containerHeight}px`);
  }
  if (img.shadow) {
    parts.push("box-shadow:0 0 3px rgba(0,0,0, .15)");
  }
  if (img.browser) {
    parts.push("box-shadow:0 -3px 0 #dedede, 0 0 3px rgba(0,0,0, .15)");
  }
  return parts.length > 0 ? parts.join("; ") + ";" : undefined;
}

const isMasonry = listingMode === "masonry";
---

{galleryImages.length > 0 && (
  <div class={`gallery gallery--${listingMode}`}>
    {isMasonry ? (
      <ul data-behavior="masonry">
        {galleryImages.map((image) => (
          <li>
            <a href={image.link} class="focusable">
              <div class={image.class} style={containerStyle(image, isMasonry)}>
                <div class="gallery__inner">
                  <img
                    width={image.width}
                    height={image.height}
                    src={image.url}
                    style={imgStyle(image, isMasonry)}
                  alt=""
                  />
                </div>
              </div>
              {displayFilenames && !isMasonry && (
                <p>{image.filename}</p>
              )}
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <ul>
        {galleryImages.map((image) => (
          <li>
            <a href={image.link} class="focusable">
              <div class={image.class} style={containerStyle(image, isMasonry)}>
                <div class="gallery__inner">
                  <img
                    width={image.width}
                    height={image.height}
                    src={image.url}
                    style={imgStyle(image, isMasonry)}
                  alt=""
                  />
                </div>
              </div>
              {displayFilenames && !isMasonry && (
                <p>{image.filename}</p>
              )}
            </a>
          </li>
        ))}
      </ul>
    )}
  </div><!-- gallery -->
)}
