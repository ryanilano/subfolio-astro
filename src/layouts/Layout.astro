---
/**
 * Main page layout — ported from upstream layouts/template.php +
 * template_colors.php. Wires the SCSS pipeline, color palette, and theme
 * assets into the standard Subfolio shell.
 *
 * Props mirror what the PHP controller passed to template.php: a page title,
 * a body CSS class, and optional breadcrumb/prev-next for navigation.
 *
 * The color palette is loaded from YAML at build time and inlined as a
 * <style> block (same approach as template_colors.php), overriding the
 * SCSS defaults.
 */
import { resolve } from "node:path";
import { siteConfig, defaultOptions, type Options } from "../lib/site.ts";
import { loadColorPalette, type ColorPalette } from "../lib/colors.ts";
import Header from "./Header.astro";
import Footer from "./Footer.astro";

export interface Props {
  /** Page title (used in <title> and breadcrumb). */
  title?: string;
  /** CSS class on <body>. */
  pageClass?: string;
  /** Breadcrumb trail. Last item has empty url. */
  breadcrumb?: { name: string; url: string }[];
  /** Is this the site root? Hides prev/next nav. */
  isRoot?: boolean;
  /** Prev/next folder links for navigation. */
  prevLink?: string | null;
  nextLink?: string | null;
  /** Display options override (merge with defaults). */
  options?: Partial<Options>;
}

const {
  title = "",
  pageClass = "",
  breadcrumb = [],
  isRoot = false,
  prevLink = null,
  nextLink = null,
  options: opts = {},
} = Astro.props;

// Merge props over defaults
const opt: Options = { ...defaultOptions, ...opts };

// Resolve color palette from YAML (build time).
// Use resolve() relative to process.cwd() because import.meta.url points into
// Vite's dist/.prerender/ output tree during SSR prerender (Astro 6 SSR mode).
const colorsPath = resolve(
  process.cwd(),
  `src/config/colors-${opt.color_palette}.yml`,
);
const palette: ColorPalette = loadColorPalette(colorsPath);

// Site metadata
const { site_title, site_meta_description, site_favicon_url, google_analytics_code } = siteConfig;

// Full page title: "Page Title — Site Title" or just "Site Title"
const fullTitle = title ? `${title} — ${site_title}` : site_title;

// Color palette CSS (ported from template_colors.php). Built as a string in
// frontmatter because Astro <style> blocks are parsed as static CSS and do NOT
// interpolate `{...}` expressions — emitted raw via <style set:html> below.
const colorCss = `
    /* BACKGROUND */
    body, #gallery ul li a div.gallery_thumbnail {
      background-color: ${palette.back};
    }
    /* BACKGROUND_SHIFT */
    .standard_paragraph code {
      background-color: ${palette.back_shift};
    }
    /* LINKS */
    .list__cell--filename {
      color: ${palette.main_link};
    }
    .list a:hover, .grid li a:hover {
      background-color: ${palette.main_link_back_hover};
    }
    /* SUB LINKS */
    a, a:link, a:visited {
      color: ${palette.sub_link};
    }
    a:hover {
      color: ${palette.sub_link_hover};
    }
    .breadcrumb a:hover, .header__logout a:hover, .header__navigation a:hover, #footer a:hover, .header__navigation a.hover {
      color: ${palette.sub_link_hover};
    }
    /* GALLERY */
    #gallery ul li a {
      color: ${palette.gallery_link};
      background-color: ${palette.gallery_back};
    }
    #gallery ul li a:hover p {
      color: ${palette.gallery_link_hover};
    }
    #gallery ul li a:hover {
      background-color: ${palette.gallery_back_hover};
    }
    /* FEATURES */
    #features ul li a {
      color: ${palette.feature_link};
      background-color: ${palette.feature_back};
    }
    #features ul li a:hover h2 {
      color: ${palette.feature_link_hover};
    }
    #features ul li a:hover {
      background-color: ${palette.feature_back_hover};
      border-color: ${palette.feature_back_hover};
    }
    #features ul li a:hover .info p {
      color: ${palette.feature_text_hover};
    }
    /* LINKS HOVER */
    a:hover .filename {
      color: ${palette.main_link_hover} !important;
    }
    /* TEXT */
    .standard_paragraph h1,
    .standard_paragraph h3,
    #features ul li a .info p,
    .standard_paragraph,
    .standard_paragraph p,
    #lock form input.field {
      color: ${palette.text};
    }
    /* TEXT_STRONG */
    .standard_paragraph h4, .standard_paragraph h5,
    .standard_paragraph strong, .standard_paragraph em, .standard_paragraph b, b, strong {
      color: ${palette.text_strong};
    }
    /* TEXT_LIGHT */
    body, .breadcrumb,
    .standard_paragraph h2,
    .standard_paragraph p small,
    .standard_paragraph p small a,
    #footer,
    .listing-header,
    .list__cell,
    .header__logout a {
      color: ${palette.text_light};
    }
    a .list__cell--filename,
    .header__logout a:hover {
      color: ${palette.text_strong};
    }
    a.list__row--empty span,
    a.list__row--empty .list__cell--filename {
      color: ${palette.text_dimmed};
    }
    #notice {
      background-color: ${palette.text_light};
    }
    /* TEXT_DIMMED */
    .grid li span.comment {
      color: ${palette.text_dimmed};
    }
    /* FLASH */
    .error {
      color: ${palette.flash};
    }
    #notice.error,
    #lock .login_feedback {
      background-color: ${palette.flash};
    }
    /* BORDERS */
    .breadcrumbtools,
    .header__navigation,
    #footer,
    #footer a#footer-home,
    #footer span.copyright {
      border-color: ${palette.border};
    }
    /* LINES */
    .standard_paragraph code,
    .standard_paragraph blockquote,
    .standard_paragraph table td,
    .standard_paragraph table tr:last-child td,
    #download_box dl,
    #download_box dd,
    #download_box #instructions,
    #info-box, #lock form,
    #lock form input.field,
    .subButton {
      border-color: ${palette.line};
    }
`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#000000" />

  {site_meta_description && <meta name="description" content={site_meta_description} />}

  <title>{fullTitle}</title>

  {site_favicon_url && (
    <>
      <link rel="icon" href={`${site_favicon_url}?v=2`} type="image/vnd.microsoft.icon" />
      <link rel="shortcut icon" href={`${site_favicon_url}?v=2`} type="image/vnd.microsoft.icon" />
    </>
  )}

  <link href="/css/main.css?v=2" type="text/css" rel="stylesheet" />
  <script is:inline>
    var A17 = window.A17 || {};
    A17.svgSupport = document.implementation.hasFeature("http://www.w3.org/TR/SVG11/feature#BasicStructure", "1.1");
    A17.browserSpec = typeof document.querySelectorAll && "addEventListener" in window && A17.svgSupport ? "html5" : "html4";
    A17.touch = "ontouchstart" in window || window.DocumentTouch && document instanceof DocumentTouch;

    (function() {
        var doc = document.documentElement;
        var str = " js " + A17.browserSpec + (A17.touch ? " touch" : " no-touch") + (A17.svgSupport ? " svg" : " no-svg");
        doc.className = doc.className.replace(/\bno-js\b/, str);
    })();

    A17.loadCSS = function(href) {
        "use strict";
        var ss = window.document.createElement("link");
        var ref = window.document.getElementsByTagName("script")[0];
        var sheets = window.document.styleSheets;
        ss.rel = "stylesheet";
        ss.href = href;
        ss.media = "only x";
        ref.parentNode.insertBefore(ss, ref);
        ss.onloadcssdefined = function(cb) {
            var defined;
            for (var i = 0; i < sheets.length; i++) {
                if (sheets[i].href && sheets[i].href.indexOf(href) > -1) {
                    defined = true;
                }
            }
            if (defined) {
                cb();
            } else {
                setTimeout(function() {
                    ss.onloadcssdefined(cb);
                });
            }
        };
        ss.onloadcssdefined(function() {
            ss.media = "all";
        });
        return ss;
    };
  </script>
  <script is:inline>A17.loadCSS("/css/icons.css");</script>

  <!-- Color palette (ported from template_colors.php). The CSS is built in
       frontmatter (colorCss) and emitted raw, because Astro <style> blocks are
       compiled as static CSS and do not interpolate expressions. -->
  <style type="text/css" media="screen" is:inline set:html={colorCss}></style>
</head>

<body class={`${pageClass}`}>
  <a class="skip-link" href="#content">Skip to content</a>
  <div id="container">
    <div id="container-inner">
      <Header
        breadcrumb={breadcrumb}
        displayHeader={opt.display_header}
        displayBreadcrumb={opt.display_breadcrumb}
        displayNavigation={opt.display_navigation}
        displayCollapseHeader={opt.display_collapse_header}
        isRoot={isRoot}
        prevLink={prevLink}
        nextLink={nextLink}
      />
      <div id="content-outer">
        <main id="content">
          <slot />
        </main>
      </div>
    </div>
    <Footer
      displayCopyright={opt.display_copyright}
      displayUpdatedSince={opt.display_updated_since}
    />
  </div>

  {google_analytics_code && (
    <>
      <script type="text/javascript" is:inline>
        var gaJsHost = (("https:" == document.location.protocol) ? "https://ssl." : "http://www.");
        document.write(unescape("%3Cscript src='" + gaJsHost + "google-analytics.com/ga.js' type='text/javascript'%3E%3C/script%3E"));
      </script>
      <script type="text/javascript" is:inline>
        try {{
        var pageTracker = _gat._getTracker("{google_analytics_code}");
        pageTracker._trackPageview();
        }} catch(err) {{}}
      </script>
    </>
  )}

  <script src="/js/main.js" is:inline></script>
</body>
</html>
