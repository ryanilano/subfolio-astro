---
/**
 * Main page layout — ported from upstream layouts/template.php +
 * template_colors.php. Wires the SCSS pipeline, color palette, and theme
 * assets into the standard Subfolio shell.
 *
 * Props mirror what the PHP controller passed to template.php: a page title,
 * a body CSS class, and optional breadcrumb/prev-next for navigation.
 *
 * The color palette is loaded from YAML at build time and inlined as a
 * <style> block (same approach as template_colors.php), overriding the
 * SCSS defaults.
 */
import { existsSync } from "node:fs";
import { resolve } from "node:path";
import { ClientRouter } from "astro:transitions";
import { siteConfig, defaultOptions, activeTheme, type Options } from "../lib/site.ts";
import { loadColorPalette, type ColorPalette } from "../lib/colors.ts";
import Header from "./Header.astro";
import Footer from "./Footer.astro";

export interface Props {
  /** Page title (used in <title> and breadcrumb). */
  title?: string;
  /** CSS class on <body>. */
  pageClass?: string;
  /** Breadcrumb trail. Last item has empty url. */
  breadcrumb?: { name: string; url: string }[];
  /** Is this the site root? Hides prev/next nav. */
  isRoot?: boolean;
  /** Prev/next folder links for navigation. */
  prevLink?: string | null;
  nextLink?: string | null;
  /** Open Graph / meta description for this page. Falls back to the site default. */
  description?: string;
  /** Open Graph image (site-root-relative or absolute). Resolved to absolute below. */
  ogImage?: string;
  /** Open Graph type: "website" for listings, "article" for file detail views. */
  ogType?: "website" | "article";
  /** Display options override (merge with defaults). */
  options?: Partial<Options>;
}

const {
  title = "",
  pageClass = "",
  breadcrumb = [],
  isRoot = false,
  prevLink = null,
  nextLink = null,
  description,
  ogImage,
  ogType = "website",
  options: opts = {},
} = Astro.props;

// Merge props over defaults
const opt: Options = { ...defaultOptions, ...opts };

// Resolve color palette from YAML (build time).
// Use resolve() relative to process.cwd() because import.meta.url points into
// Vite's dist/.prerender/ output tree during SSR prerender (Astro 6 SSR mode).
const colorsPath = resolve(
  process.cwd(),
  `src/config/colors-${opt.color_palette}.yml`,
);
const palette: ColorPalette = loadColorPalette(colorsPath);

// Active-theme override sheet (compiled by gen-css.mjs → public/css/theme-<name>.css).
// Linked only when it exists, so the default theme (whose look IS main.css) and any
// theme without a sheet add nothing — no 404. Gate via fs since frontmatter runs at
// build (SSG); resolve from cwd for the same reason as colorsPath above.
const hasThemeCss = existsSync(
  resolve(process.cwd(), `public/css/theme-${activeTheme}.css`),
);

// Site metadata
const {
  site_title,
  site_meta_description,
  site_favicon_url,
  google_analytics_code,
  enable_view_transitions,
} = siteConfig;

// Derive the favicon MIME type from its extension so the <link type> matches the
// actual asset (PNG/SVG/ICO) instead of being hard-coded to ICO.
const FAVICON_MIME: Record<string, string> = {
  ".png": "image/png",
  ".svg": "image/svg+xml",
  ".gif": "image/gif",
  ".ico": "image/vnd.microsoft.icon",
};
const faviconExt = site_favicon_url?.split("?")[0].match(/\.[a-z0-9]+$/i)?.[0].toLowerCase();
const faviconType = (faviconExt && FAVICON_MIME[faviconExt]) || "image/vnd.microsoft.icon";

// Full page title: "Page Title — Site Title" or just "Site Title"
const fullTitle = title ? `${title} — ${site_title}` : site_title;

// --- Open Graph / Twitter Card -------------------------------------------
// Absolute canonical URL for this page (Astro.site is set in astro.config).
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
// Opt out of indexing for non-public deploys (e.g. archive.ilano.fyi). Set at
// build time via SUBFOLIO_NOINDEX=1; default (demo) build stays indexable.
// process.env (not import.meta.env) — matches how every other SUBFOLIO_* var is
// read in this codebase, and Vite won't expose an unprefixed var on import.meta.
const noindex = process.env.SUBFOLIO_NOINDEX === "1";
// Description: per-page override → site default → undefined (tag omitted).
const ogDescription = description || site_meta_description || undefined;
// og:image must be absolute. Callers pass a root-relative thumbnail URL.
const ogImageUrl = ogImage ? new URL(ogImage, Astro.site).href : undefined;

// Color palette CSS (ported from template_colors.php). Built as a string in
// frontmatter because Astro <style> blocks are parsed as static CSS and do NOT
// interpolate `{...}` expressions — emitted raw via <style set:html> below.
const colorCss = `
    /* BACKGROUND */
    body, .gallery li a div.gallery_thumbnail {
      background-color: ${palette.back};
    }
    /* BACKGROUND_SHIFT */
    .standard_paragraph code {
      background-color: ${palette.back_shift};
    }
    /* LINKS */
    .list__cell--filename {
      color: ${palette.main_link};
    }
    a.list__row:hover {
      background-color: ${palette.main_link_back_hover};
    }
    /* SUB LINKS */
    a, a:link, a:visited {
      color: ${palette.sub_link};
    }
    a:hover {
      color: ${palette.sub_link_hover};
    }
    .breadcrumb a:hover, .header__logout a:hover, .header__navigation a:hover, #footer a:hover, .header__navigation a.hover {
      color: ${palette.sub_link_hover};
    }
    /* GALLERY */
    .gallery li a {
      color: ${palette.gallery_link};
      background-color: ${palette.gallery_back};
    }
    .gallery li a:hover p {
      color: ${palette.gallery_link_hover};
    }
    .gallery li a:hover {
      background-color: ${palette.gallery_back_hover};
    }
    /* FEATURES */
    #features ul li a {
      color: ${palette.feature_link};
      background-color: ${palette.feature_back};
    }
    #features ul li a:hover h2 {
      color: ${palette.feature_link_hover};
    }
    #features ul li a:hover {
      background-color: ${palette.feature_back_hover};
      border-color: ${palette.feature_back_hover};
    }
    #features ul li a:hover .info p {
      color: ${palette.feature_text_hover};
    }
    /* LINKS HOVER */
    a:hover .filename {
      color: ${palette.main_link_hover} !important;
    }
    /* TEXT */
    .standard_paragraph h1,
    .standard_paragraph h3,
    #features ul li a .info p,
    .standard_paragraph,
    .standard_paragraph p,
    #lock form input.field {
      color: ${palette.text};
    }
    /* TEXT_STRONG */
    .standard_paragraph h4, .standard_paragraph h5,
    .standard_paragraph strong, .standard_paragraph em, .standard_paragraph b, b, strong {
      color: ${palette.text_strong};
    }
    /* TEXT_LIGHT */
    body, .breadcrumb,
    .standard_paragraph h2,
    .standard_paragraph p small,
    .standard_paragraph p small a,
    #footer,
    .listing-header,
    .list__cell,
    .header__logout a {
      color: ${palette.text_light};
    }
    a .list__cell--filename,
    .header__logout a:hover {
      color: ${palette.text_strong};
    }
    a.list__row--empty span,
    a.list__row--empty .list__cell--filename {
      color: ${palette.text_dimmed};
    }
    #notice {
      background-color: ${palette.text_light};
    }
    /* TEXT_DIMMED */
    .list__cell--comment {
      color: ${palette.text_light};
    }
    /* FLASH */
    .error {
      color: ${palette.flash};
    }
    #notice.error,
    #lock .login_feedback {
      background-color: ${palette.flash};
    }
    /* BORDERS */
    .breadcrumbtools,
    .header__navigation,
    #footer,
    #footer a#footer-home,
    #footer span.copyright {
      border-color: ${palette.border};
    }
    /* LINES */
    .standard_paragraph code,
    .standard_paragraph blockquote,
    .standard_paragraph table td,
    .standard_paragraph table tr:last-child td,
    #download_box dl,
    #download_box dd,
    #download_box #instructions,
    #info-box, #lock form,
    #lock form input.field,
    .subButton {
      border-color: ${palette.line};
    }
`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#000000" />

  {/* Opt-in SPA navigation (Astro View Transitions). Inert unless the flag is
      set — see siteConfig.enable_view_transitions for the A17-reinit caveat. */}
  {enable_view_transitions && <ClientRouter />}

  {ogDescription && <meta name="description" content={ogDescription} />}
  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <title>{fullTitle}</title>

  <link rel="canonical" href={canonicalUrl} />

  {/* Open Graph (Facebook, LinkedIn, Slack, …) */}
  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content={site_title} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:url" content={canonicalUrl} />
  {ogDescription && <meta property="og:description" content={ogDescription} />}
  {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}

  {/* Twitter Card */}
  <meta name="twitter:card" content={ogImageUrl ? "summary_large_image" : "summary"} />
  <meta name="twitter:title" content={fullTitle} />
  {ogDescription && <meta name="twitter:description" content={ogDescription} />}
  {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}

  {site_favicon_url && (
    <>
      <link rel="icon" href={`${site_favicon_url}?v=2`} type={faviconType} />
      <link rel="shortcut icon" href={`${site_favicon_url}?v=2`} type={faviconType} />
    </>
  )}

  <link rel="preload" href="/fonts/Inter-Variable-latin.woff2" as="font" type="font/woff2" crossorigin />
  <link href="/css/main.css?v=2" type="text/css" rel="stylesheet" />
  <script is:inline>
    var A17 = window.A17 || {};
    A17.svgSupport = document.implementation.hasFeature("http://www.w3.org/TR/SVG11/feature#BasicStructure", "1.1");
    A17.browserSpec = typeof document.querySelectorAll && "addEventListener" in window && A17.svgSupport ? "html5" : "html4";
    A17.touch = "ontouchstart" in window || window.DocumentTouch && document instanceof DocumentTouch;

    (function() {
        var doc = document.documentElement;
        var str = " js " + A17.browserSpec + (A17.touch ? " touch" : " no-touch") + (A17.svgSupport ? " svg" : " no-svg");
        doc.className = doc.className.replace(/\bno-js\b/, str);
    })();
  </script>

  <!-- icons.css loaded non-render-blocking via the native media-swap pattern
       (replaces the old JS A17.loadCSS). The browser fetches it at low priority
       as a print sheet, then onload flips it to all. <noscript> keeps it working
       with JS disabled. -->
  <link rel="stylesheet" href="/css/icons.css" media="print" onload="this.media='all'" />
  <noscript><link rel="stylesheet" href="/css/icons.css" /></noscript>

  <!-- Color palette (ported from template_colors.php). The CSS is built in
       frontmatter (colorCss) and emitted raw, because Astro <style> blocks are
       compiled as static CSS and do not interpolate expressions. -->
  <style type="text/css" media="screen" is:inline set:html={colorCss}></style>

  {/* Active-theme override sheet — last in <head> so it wins the cascade over
      both main.css and the inline color palette above. */}
  {hasThemeCss && (
    <link href={`/css/theme-${activeTheme}.css?v=1`} type="text/css" rel="stylesheet" />
  )}
</head>

<body class={`${pageClass}`}>
  <a class="skip-link" href="#content">Skip to content</a>
  <div id="container">
    <div id="container-inner">
      <Header
        breadcrumb={breadcrumb}
        displayHeader={opt.display_header}
        displayBreadcrumb={opt.display_breadcrumb}
        displayNavigation={opt.display_navigation}
        displayCollapseHeader={opt.display_collapse_header}
        isRoot={isRoot}
        prevLink={prevLink}
        nextLink={nextLink}
      />
      <div id="content-outer">
        <main id="content">
          <slot />
        </main>
      </div>
    </div>
    <Footer
      displayCopyright={opt.display_copyright}
      displayUpdatedSince={opt.display_updated_since}
    />
  </div>

  {google_analytics_code && (
    <>
      <script type="text/javascript" is:inline>
        var gaJsHost = (("https:" == document.location.protocol) ? "https://ssl." : "http://www.");
        document.write(unescape("%3Cscript src='" + gaJsHost + "google-analytics.com/ga.js' type='text/javascript'%3E%3C/script%3E"));
      </script>
      <script type="text/javascript" is:inline>
        try {{
        var pageTracker = _gat._getTracker("{google_analytics_code}");
        pageTracker._trackPageview();
        }} catch(err) {{}}
      </script>
    </>
  )}

  <script src="/js/main.js?v=2" defer is:inline></script>
</body>
</html>
